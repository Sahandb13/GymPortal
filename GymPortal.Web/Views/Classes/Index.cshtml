@model List<GymPortal.Domain.Entities.GymClass>

<h1>Training Classes</h1>

<div class="feature-grid">
    @foreach (var gymClass in Model)
    {
        <div class="feature-card">
            <h3>@gymClass.Name</h3>

            <p>
                @gymClass.Date.ToShortDateString()
                · Coach @gymClass.Instructor
            </p>

            <form method="post" action="/Booking/Create">
                <input type="hidden" name="gymClassId" value="@gymClass.Id" />
                <button class="btn-primary" type="submit">
                    Book Class
                </button>
            </form>
        </div>
    }
</div>