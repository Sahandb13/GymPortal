<section class="auth-page">
    <div class="auth-card">
        <h1>Set Your Password</h1>

        <p class="auth-intro">
            Set a strong password to protect your account. Your password should be at least
            8 characters long and include uppercase, lowercase, numbers and symbols.
        </p>

        <div class="auth-divider"></div>

        <form>
            <label>Email Address</label>
            <input placeholder="username@domain.com" />

            <label>Password</label>
            <input type="password" placeholder="Enter Password" />

            <button class="auth-submit" type="button">
                Continue <span>›</span>
            </button>

            <label class="terms-row">
                <input type="checkbox" />
                <span>Accept user terms and conditions</span>
            </label>
        </form>
    </div>
</section>