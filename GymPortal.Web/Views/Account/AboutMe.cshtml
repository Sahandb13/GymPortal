<h1>My Account</h1>

<p>Email: @ViewBag.Email</p>

<div class="feature-grid">

    <div class="feature-card">
        <h3>My Membership</h3>
        <p>Status: Active</p>
        <a class="btn-primary" href="/Membership">View Membership</a>
    </div>

    <div class="feature-card">
        <h3>My Bookings</h3>
        <p>View and cancel your booked classes.</p>
        <a class="btn-primary" href="/Booking/MyBookings">View Bookings</a>
    </div>

    <div class="feature-card">
        <h3>Profile</h3>
        <p>Edit your personal information.</p>
        <a class="btn-dark" href="#">Edit Profile</a>
    </div>

    <div class="feature-card">
        <h3>Delete Account</h3>
        <p>Permanently remove your account.</p>
        <form method="post" action="/Account/Delete">
            <button class="btn-dark">Delete</button>
        </form>
    </div>

</div>