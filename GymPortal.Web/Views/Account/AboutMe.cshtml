<section class="account-page">

    <!-- =====================================================
                        KONTO-SIDA
    ====================================================== -->

    <h1>My Account</h1>

    <div class="account-layout">

        <!-- =====================================================
                            SIDOMENY
        ====================================================== -->

        <aside class="account-sidebar">

            <img src="/images/aboutme-image.png" alt="Profile image" />

            <div class="account-menu">

                <a class="active" href="/Account/AboutMe">
                    About Me ›
                </a>

                <a href="/Membership/MyMembership">
                    My Membership ›
                </a>

                <a href="/Booking/MyBookings">
                    My Booking ›
                </a>

                <form method="post" action="/Account/Logout">

                    <button class="btn-dark" type="submit">
                        Sign Out ›
                    </button>

                </form>

            </div>

        </aside>


        <!-- =====================================================
                           PROFILINFORMATION
        ====================================================== -->

        <div class="account-main">

            <div class="account-card">

                <h2>About Me</h2>

                <!-- AI-stöd användes vid uppbyggnaden av profilformuläret -->
                <form method="post" action="/Account/EditProfile">

                    <label>First Name</label>

                    <input name="FirstName"
                           type="text"
                           placeholder="Enter First Name" />

                    <label>Last Name</label>

                    <input name="LastName"
                           type="text"
                           placeholder="Enter Last Name" />

                    <label>Email Address</label>

                    <input value="@ViewBag.Email" readonly />

                    <button class="btn-primary save-btn" type="submit">
                        Save Changes ›
                    </button>

                </form>


                <!-- =====================================================
                              TA BORT KONTO
                ====================================================== -->

                <form method="post" action="/Account/Delete">

                    <button class="btn-dark"
                            type="submit"
                            style="margin-top:20px;">

                        Delete Account

                    </button>

                </form>

            </div>


            <!-- =====================================================
                              STATISTIK
            ====================================================== -->

            <div class="stats-card">

                <h2>My Statistics</h2>

                <div class="stat-row">
                    <span>Check-in (last 30 days)</span>
                    <strong>25</strong>
                </div>

                <div class="progress">
                    <div style="width: 75%;"></div>
                </div>

                <div class="stat-row">
                    <span>Weight Goal</span>
                    <strong>50%</strong>
                </div>

                <div class="progress">
                    <div style="width: 50%;"></div>
                </div>

                <div class="stat-row">
                    <span>Current BMI</span>
                    <strong>27</strong>
                </div>

                <div class="progress">
                    <div style="width: 65%;"></div>
                </div>

            </div>

        </div>

    </div>

</section>